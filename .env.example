# DeepInfra API Configuration
# Replace the placeholder value below with your actual API key.
# A key was provided in the instructions: 8Va8vKH5ZeexTuPpaXVJh1hMm0hcIUz7
DEEPINFRA_API_KEY=your_deepinfra_api_key_here

# DeepInfra OpenAI-compatible Endpoint
